  "swiftImplementationMapping": {
    "DesignTokens.swift": [
      "Replace single flat card shadow with level1Card and level2RaisedCard helpers.",
      "Add brand orange, warm orange, soft orange, blue, green, purple, pink, and yellow support colors.",
      "Add shared primaryCTA, secondaryCTA, floatingIconButton, and dimensional card modifiers.",
      "Add reusable spacing, radius, and typography constants."
    ],
    "CareerVividMobileMVPView.swift": [
      "Update custom tab bar to use glass background, larger selected capsule, and orange selected state.",
      "Keep tab bar floating above safe area with strong but soft shadow."
    ],
    "HomeView.swift": [
      "Make progress gauge card larger and more dimensional.",
      "Use white cards with orange progress arcs and secondary blue/green status metrics."
    ],
    "JobsView.swift": [
      "Give job rows stronger card depth, orange selected filter, and status pill hierarchy.",
      "Use company initial avatar blocks with soft fills."
    ],
    "PracticeView.swift": [
      "Wrap previous reports and setup controls in white elevated section cards.",
      "Use orange primary CTA and orange selected role/type states.",
      "Keep previous report rows compact and tappable."
    ],
    "ResumeView.swift": [
      "Use white elevated resume cards, orange document icon band, and soft orange add button.",
      "Preserve swipe-to-delete behavior."
    ],
    "InterviewReportView or PracticeView report state": [
      "Render markdown through AttributedString before displaying any report text.",
      "Use tactile weakness rows and bottom dual-button action layout."
    ]
  },
