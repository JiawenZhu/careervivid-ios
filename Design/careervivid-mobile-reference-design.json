  "accessibility": {
    "minimumTouchTarget": 44,
    "contrast": "Primary text and selected controls must meet WCAG AA contrast.",
    "dynamicType": "Text should support Dynamic Type without clipping inside cards.",
    "reduceMotion": "Disable pulse and spring animations when Reduce Motion is enabled.",
    "voiceOver": [
      "Score rings announce numeric score and label.",
      "Job cards announce title, company, stage, and match percent.",
      "Interview weakness rows announce the weakness title and that it starts targeted practice.",
      "Swipe delete actions have explicit labels."
    ]
  },
  "doNot": [
    "Do not convert the app into a one-note orange theme.",
    "Do not use heavy gradients as page backgrounds for normal dashboard screens.",
    "Do not place cards inside other cards unless the inner card is a repeated item inside a section.",
    "Do not expose raw markdown symbols in report text.",
    "Do not use oversized hero typography inside compact cards.",
    "Do not let the bottom tab bar cover primary content or final report actions."
  ]
